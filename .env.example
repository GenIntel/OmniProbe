# OmniProbe environment configuration.
# Copy to .env and set paths for your machine. .env is gitignored.

# CUDA (point at your CUDA toolkit if it is not auto-detected)
CUDA_HOME=/path/to/cuda

# Model cache directories (keep large hub/HF downloads off your home volume)
HF_HOME=/path/to/cache/hf
HUGGINGFACE_HUB_CACHE=/path/to/cache/hf/hub
TORCH_HOME=/path/to/cache/torch
